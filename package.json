{
  "name": "botdock",
  "version": "0.0.1",
  "description": "Local agent command center",
  "type": "module",
  "bin": {
    "botdock": "./bin/botdock"
  },
  "scripts": {
    "cli": "bun src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts",
    "build": "bash scripts/build.sh",
    "build:all": "bash scripts/build-all.sh"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
