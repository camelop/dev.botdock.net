bun.lockb
*.log
.DS_Store

# local test data dirs — glob catches `my_test`, `my_test_2`, etc. BotDock
# data dirs under the repo root include private/keys/**; they MUST NOT
# get committed. v0.6.4 leaked a managed-local private key exactly
# because this pattern wasn't broad enough — see git log for that fix.
scratch/
my_test*/

# Vite build output
web/dist/

# Compiled binaries
dist-bin/

# Claude Code per-machine permission overrides + scheduling runtime state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Agent skills installed into this repo for dev — the canonical source
# is the orphan `skill/botdock-context` branch, not files under main.
.claude/skills/

# BotDock runtime state written by the shim when a session runs in this repo
.botdock/

# Upstream design assets (source zips etc.) — only the picked-out PNGs in
# web/public/ should land in git.
BotDock Logo.zip
*.zip
